#!/usr/bin/env bash

set -euo pipefail

REAL_SCRIPT_DIR=$(dirname "$(realpath "$0")")

REAL_CLAUDE_CONFIG_DIR="$(realpath "${CLAUDE_CONFIG_DIR:-${HOME}/.claude}")"

exec "$REAL_SCRIPT_DIR/sbx" \
    --git \
    --cwd \
    --awscli \
    --cdk \
    --write "${HOME}/.claude" \
    --write "${CLAUDE_CONFIG_DIR:-${HOME}/.claude}" \
    --write "${REAL_CLAUDE_CONFIG_DIR}" \
    claude --dangerously-skip-permissions "$@"
